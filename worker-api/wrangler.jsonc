{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "worker-api",
  "main": "src/index.js",
  "compatibility_date": "2026-06-12",
  "compatibility_flags": ["nodejs_compat"],

  "observability": {
    "enabled": true
  },

  "upload_source_maps": true,

  "r2_buckets": [
    {
      "binding": "IMAGES_BUCKET",
      "bucket_name": "scrapbook-images"
    }
  ]
}